<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.boobyclient.launcher.ModernLauncherController">

    <!-- Background Region (Full Screen) -->
    <Region styleClass="main-background"/>
    
    <!-- Dark Overlay -->
    <Region style="-fx-background-color: rgba(0, 0, 0, 0.4);"/>

    <HBox spacing="0">
        <!-- Sidebar Navigation -->
        <VBox prefWidth="240" spacing="32" styleClass="sidebar">
            <padding><Insets top="48" right="24" bottom="48" left="24"/></padding>
            
            <VBox spacing="8" alignment="CENTER">
                <Label text="BOOBY" styleClass="logo-text"/>
                <Label text="PREMIUM" styleClass="premium-badge"/>
            </VBox>

            <VBox spacing="12" VBox.vgrow="ALWAYS">
                <Button text="HOME" styleClass="nav-button" onAction="#showHome" maxWidth="Infinity"/>
                <Button text="SETTINGS" styleClass="nav-button" onAction="#showSettings" maxWidth="Infinity"/>
                <Button text="PROFILES" styleClass="nav-button" onAction="#showProfiles" maxWidth="Infinity"/>
            </VBox>
            
            <VBox spacing="12" alignment="BOTTOM_CENTER">
                <Label fx:id="clientVersionLabel" text="1.0.2" styleClass="version-text"/>
            </VBox>
        </VBox>

        <!-- Main Content Area -->
        <StackPane fx:id="contentPane" HBox.hgrow="ALWAYS">
            <!-- Home Screen -->
            <VBox fx:id="homeScreen" spacing="32" alignment="CENTER">
                <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>
                
                <VBox spacing="24" styleClass="glass-card" maxWidth="500">
                    <VBox spacing="8" alignment="CENTER">
                        <Label fx:id="usernameLabel" text="NOT LOGGED IN" styleClass="subtitle-label"/>
                        <Separator maxWidth="100" style="-fx-opacity: 0.3;"/>
                    </VBox>

                    <StackPane>
                        <Button fx:id="loginButton" text="LOGIN WITH MICROSOFT" styleClass="primary-button" onAction="#handleLogin" maxWidth="Infinity"/>
                        <Button fx:id="logoutButton" text="LOGOUT" styleClass="danger-button" visible="false" managed="false" onAction="#handleLogout" maxWidth="Infinity"/>
                    </StackPane>

                    <VBox spacing="16">
                        <VBox spacing="8">
                            <Label text="MINECRAFT VERSION" styleClass="tiny-label"/>
                            <ComboBox fx:id="versionSelector" disable="true" maxWidth="Infinity"/>
                        </VBox>
                        
                        <Button fx:id="launchButton" text="PLAY" styleClass="play-button" onAction="#launchGame" disable="true" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="8" alignment="CENTER">
                        <Label fx:id="statusLabel" text="AUTHENTICATION REQUIRED" styleClass="status-text"/>
                        <ProgressBar fx:id="launchProgress" visible="false" managed="false" maxWidth="Infinity" prefHeight="6"/>
                    </VBox>
                </VBox>
            </VBox>

            <!-- Settings Screen -->
            <VBox fx:id="settingsScreen" spacing="24" visible="false">
                <padding><Insets top="64" right="64" bottom="64" left="64"/></padding>
                <Label text="SETTINGS" styleClass="title-label"/>
                
                <VBox spacing="24" styleClass="glass-card" maxWidth="600">
                    <HBox alignment="CENTER_LEFT" spacing="32">
                        <Label text="MEMORY" styleClass="tiny-label" prefWidth="120"/>
                        <ComboBox fx:id="memorySelector" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="32">
                        <Label text="THEME" styleClass="tiny-label" prefWidth="120"/>
                        <ComboBox fx:id="themeSelector" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                    <Separator style="-fx-opacity: 0.1;"/>
                    <Button fx:id="saveSettingsButton" text="SAVE CHANGES" styleClass="primary-button" onAction="#saveSettings" maxWidth="Infinity"/>
                </VBox>
            </VBox>

            <!-- Profiles Screen -->
            <VBox fx:id="profilesScreen" spacing="24" visible="false">
                <padding><Insets top="64" right="64" bottom="64" left="64"/></padding>
                <Label text="PROFILES" styleClass="title-label"/>
                
                <VBox spacing="24" styleClass="glass-card" VBox.vgrow="ALWAYS">
                    <HBox spacing="16">
                        <TextField fx:id="profileNameField" promptText="NEW PROFILE NAME..." HBox.hgrow="ALWAYS"/>
                        <Button text="ADD" styleClass="primary-button" onAction="#createProfile" prefWidth="100"/>
                    </HBox>
                    <ListView fx:id="profilesList" VBox.vgrow="ALWAYS"/>
                    <HBox spacing="16" alignment="CENTER_RIGHT">
                        <Button text="DELETE" styleClass="danger-button" onAction="#deleteProfile"/>
                        <Button text="SELECT" styleClass="primary-button" onAction="#loadProfile" prefWidth="120"/>
                    </HBox>
                </VBox>
            </VBox>
        </StackPane>
    </HBox>
</StackPane>
