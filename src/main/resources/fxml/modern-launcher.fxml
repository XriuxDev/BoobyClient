<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.boobyclient.launcher.ModernLauncherController"
            styleClass="border-pane">

    <!-- Top Navigation Bar -->
    <top>
        <VBox styleClass="top">
            <HBox alignment="CENTER_LEFT" spacing="24">
                <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="BOOBY CLIENT" styleClass="title-label"/>
                    <Label text="PREMIUM" styleClass="accent-text" style="-fx-font-size: 10; -fx-background-color: rgba(99, 102, 241, 0.1); -fx-padding: 4 8; -fx-background-radius: 12;"/>
                </HBox>
                
                <Separator orientation="VERTICAL" style="-fx-padding: 0 8; -fx-min-width: 2; opacity: 0.2;"/>

                <HBox spacing="8" HBox.hgrow="ALWAYS">
                    <Button text="Home" styleClass="button" onAction="#showHome"/>
                    <Button text="Settings" styleClass="button" onAction="#showSettings"/>
                    <Button text="Profiles" styleClass="button" onAction="#showProfiles"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- Main Content Area -->
    <center>
        <StackPane fx:id="contentPane">
            <!-- Home Screen -->
            <VBox fx:id="homeScreen" spacing="24" styleClass="border-pane">
                <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>
                <HBox spacing="32" VBox.vgrow="ALWAYS">
                    <!-- Left Side - Launch Section -->
                    <VBox fx:id="loginSection" spacing="24" styleClass="card" HBox.hgrow="ALWAYS" maxWidth="450">
                        <VBox spacing="8">
                            <Label text="Authentication" styleClass="subtitle-label"/>
                            <Label fx:id="usernameLabel" text="Not logged in" styleClass="muted-text"/>
                        </VBox>

                        <HBox spacing="12">
                            <Button fx:id="loginButton" text="Login with Microsoft" styleClass="primary-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            <Button fx:id="logoutButton" text="Logout" styleClass="danger-button" visible="false" managed="false"/>
                        </HBox>

                        <Separator style="-fx-opacity: 0.5;"/>

                        <VBox spacing="16" VBox.vgrow="ALWAYS">
                            <Label text="Quick Launch" styleClass="subtitle-label"/>
                            <VBox spacing="8">
                                <Label text="Version" styleClass="muted-text"/>
                                <ComboBox fx:id="versionSelector" disable="true" maxWidth="Infinity"/>
                            </VBox>
                        </VBox>

                        <VBox spacing="12">
                            <Button fx:id="launchButton" text="Launch Game" styleClass="primary-button" style="-fx-font-size: 16; -fx-padding: 16;" onAction="#launchGame" disable="true" maxWidth="Infinity"/>
                            <Label fx:id="statusLabel" text="Please login first" styleClass="muted-text" alignment="CENTER" maxWidth="Infinity"/>
                            <ProgressBar fx:id="launchProgress" visible="false" managed="false" maxWidth="Infinity" prefHeight="4"/>
                        </VBox>
                    </VBox>

                    <!-- Right Side - News/Info -->
                    <VBox spacing="24" styleClass="card" HBox.hgrow="ALWAYS">
                        <Label text="Client Information" styleClass="subtitle-label"/>

                        <HBox spacing="32">
                            <VBox spacing="4">
                                <Label text="Version" styleClass="muted-text"/>
                                <Label fx:id="clientVersionLabel" text="1.0.0" style="-fx-font-weight: bold;"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Target" styleClass="muted-text"/>
                                <Label text="Minecraft 1.21+" style="-fx-font-weight: bold;"/>
                            </VBox>
                        </HBox>

                        <Separator style="-fx-opacity: 0.5;"/>

                        <VBox spacing="12">
                            <Label text="Features" styleClass="subtitle-label"/>
                            <Label text="✓ Microsoft OAuth Login" styleClass="muted-text"/>
                            <Label text="✓ In-Game HUD Menu (Right-Shift)" styleClass="muted-text"/>
                            <Label text="✓ Toggle Sprint Fix" styleClass="muted-text"/>
                            <Label text="✓ FPS &amp; Ping Counters" styleClass="muted-text"/>
                            <Label text="✓ Profile Manager" styleClass="muted-text"/>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS"/>

                        <VBox spacing="8" style="-fx-background-color: rgba(16, 185, 129, 0.1); -fx-padding: 16; -fx-background-radius: 8;">
                            <Label text="Vanilla Compliant" styleClass="success-text" style="-fx-font-weight: bold;"/>
                            <Label text="This client provides no unfair advantages and is safe for competitive multiplayer." styleClass="muted-text" wrapText="true"/>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Settings Screen -->
            <VBox fx:id="settingsScreen" spacing="24" styleClass="border-pane">
                <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>
                
                <Label text="Settings" styleClass="title-label"/>

                <VBox spacing="20" styleClass="card" maxWidth="600">
                    <HBox alignment="CENTER_LEFT" spacing="24">
                        <Label text="Allocated Memory:" prefWidth="150"/>
                        <ComboBox fx:id="memorySelector" prefWidth="200"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="24">
                        <Label text="Theme:" prefWidth="150"/>
                        <ComboBox fx:id="themeSelector" prefWidth="200"/>
                    </HBox>
                    
                    <Separator style="-fx-opacity: 0.2; -fx-padding: 8 0;"/>

                    <CheckBox text="Auto-launch on startup" styleClass="check-box"/>
                    <CheckBox text="Keep launcher open after game starts" styleClass="check-box"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>
                
                <HBox>
                    <Button fx:id="saveSettingsButton" text="Save Settings" styleClass="primary-button" onAction="#saveSettings"/>
                </HBox>
            </VBox>

            <!-- Profiles Screen -->
            <VBox fx:id="profilesScreen" spacing="24" styleClass="border-pane">
                <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>
                
                <Label text="Profile Manager" styleClass="title-label"/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <TextField fx:id="profileNameField" promptText="Enter new profile name..." prefWidth="300" style="-fx-padding: 12 16;"/>
                    <Button text="Create Profile" styleClass="primary-button" onAction="#createProfile"/>
                </HBox>

                <VBox spacing="16" styleClass="card" VBox.vgrow="ALWAYS">
                    <Label text="Saved Profiles" styleClass="subtitle-label"/>
                    <ListView fx:id="profilesList" VBox.vgrow="ALWAYS"/>
                    
                    <HBox spacing="12" alignment="CENTER_RIGHT">
                        <Button text="Delete" styleClass="danger-button" style="-fx-padding: 10 20;" onAction="#deleteProfile"/>
                        <Button text="Load Profile" styleClass="primary-button" onAction="#loadProfile"/>
                    </HBox>
                </VBox>
            </VBox>
        </StackPane>
    </center>

</BorderPane>
